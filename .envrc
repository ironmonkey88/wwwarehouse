# Prepend Critical Paths
export PATH="/usr/local/share/google-cloud-sdk/bin:/opt/homebrew/bin:/usr/local/bin:$PATH"

# Enforce Python 3.11 for System Tools (e.g., gcloud)
export CLOUDSDK_PYTHON="/usr/local/bin/python3.11"

# Load the local virtual environment automatically
export VIRTUAL_ENV="$(pwd)/.venv"
export PATH="$VIRTUAL_ENV/bin:$PATH"
